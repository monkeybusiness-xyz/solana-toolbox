---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Solana Toolbox',
  description = 'A curated directory of tools, libraries, and resources for building on and using Solana.',
  image,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site).href : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Solana Toolbox" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://solana-toolbox.com/#organization",
          "name": "Solana Toolbox",
          "url": "https://solana-toolbox.com/",
          "sameAs": ["https://github.com/monkeybusiness-xyz/solana-toolbox"],
        },
        {
          "@type": "WebSite",
          "@id": "https://solana-toolbox.com/#website",
          "name": "Solana Toolbox",
          "url": Astro.site?.href,
          "description": description,
          "publisher": { "@id": "https://solana-toolbox.com/#organization" },
        },
      ],
    })} />
    <!-- Google tag (gtag.js) — deferred to avoid blocking LCP -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <script>
      window.addEventListener('load', function() {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-4VQYB5F5VC';
        s.async = true;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-4VQYB5F5VC');
      });
    </script>
  </head>
  <body class="min-h-screen">
    <header class="border-b border-[#1E1E2E] sticky top-0 z-50 backdrop-blur-sm bg-[#0A0A0F]/90">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: linear-gradient(135deg, #9945FF, #14F195);">
            <span class="text-black font-bold text-sm">S</span>
          </div>
          <span class="font-semibold text-white text-lg tracking-tight">
            Solana <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #9945FF, #14F195);">Toolbox</span>
          </span>
        </a>
        <nav class="flex items-center gap-6 text-sm text-gray-400">
          <a href="https://github.com/monkeybusiness-xyz/solana-toolbox" target="_blank" rel="noopener" class="hover:text-white transition-colors">
            Submit a tool
          </a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="border-t border-[#1E1E2E] mt-24 py-10 text-center text-sm text-gray-500">
      <div class="max-w-7xl mx-auto px-4 space-y-3">
        <p>
          solana-toolbox.com — community curated.
          <a href="https://github.com/monkeybusiness-xyz/solana-toolbox" target="_blank" rel="noopener" class="text-gray-400 hover:text-white transition-colors ml-1">
            Add or improve a listing →
          </a>
        </p>
        <p class="flex items-center justify-center gap-4">
          <a href="/about" class="hover:text-gray-300 transition-colors">About</a>
          <a href="/privacy" class="hover:text-gray-300 transition-colors">Privacy policy</a>
          <a href="/terms" class="hover:text-gray-300 transition-colors">Terms of use</a>
        </p>
      </div>
    </footer>
  </body>
</html>
