---
interface Props {
  name: string;
  description: string;
  url: string;
  github: string | null;
  tags: string[];
  audience: 'user' | 'developer' | 'both';
}

const { name, description, url, github, tags, audience } = Astro.props;

const audienceLabel = {
  user: { text: 'User tool', class: 'bg-purple-950/60 text-purple-300 border border-purple-800/50' },
  developer: { text: 'Developer tool', class: 'bg-sky-950/60 text-sky-300 border border-sky-800/50' },
  both: { text: 'User + developer', class: 'bg-emerald-950/60 text-emerald-300 border border-emerald-800/50' },
}[audience];
---

<div class="group rounded-xl border border-[#1E1E2E] bg-[#111118] p-5 hover:border-[#9945FF]/40 transition-all duration-200 hover:bg-[#13131e] flex flex-col gap-3">
  <div class="flex items-start justify-between gap-3">
    <a href={url} target="_blank" rel="noopener noreferrer" class="font-semibold text-white group-hover:text-[#14F195] transition-colors leading-tight">
      {name}
    </a>
    <span class={`shrink-0 text-xs px-2 py-0.5 rounded-full font-medium ${audienceLabel.class}`}>
      {audienceLabel.text}
    </span>
  </div>

  <p class="text-sm text-gray-400 leading-relaxed flex-1">
    {description}
  </p>

  <div class="flex items-center justify-between gap-2 pt-1">
    <div class="flex flex-wrap gap-1.5">
      {tags.slice(0, 4).map(tag => (
        <span class="text-xs text-gray-400 bg-[#1E1E2E] px-2 py-0.5 rounded-md">
          {tag}
        </span>
      ))}
    </div>

    <div class="flex items-center gap-3 shrink-0">
      {github && (
        <a href={github} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-gray-200 transition-colors" title="GitHub">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
        </a>
      )}
      <a href={url} target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-[#14F195] transition-colors text-xs font-medium">
        Visit →
      </a>
    </div>
  </div>
</div>
