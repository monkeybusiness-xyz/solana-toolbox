---
import Base from '../layouts/Base.astro';
import ToolCard from '../components/ToolCard.astro';
import categories from '../../data/categories.json';

// Load all tool files
const toolFiles = import.meta.glob('../../data/tools/*.json', { eager: true });
const allTools: Record<string, any[]> = {};
for (const [path, mod] of Object.entries(toolFiles)) {
  const slug = path.split('/').pop()!.replace('.json', '');
  allTools[slug] = (mod as any).default;
}

const totalTools = Object.values(allTools).reduce((sum, arr) => sum + arr.length, 0);

const itemLists = categories.map((cat) => ({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": `https://solana-toolbox.com/#list-${cat.slug}`,
  "name": cat.name,
  "description": cat.description,
  "url": `https://solana-toolbox.com/#${cat.slug}`,
  "numberOfItems": (allTools[cat.slug] ?? []).length,
  "itemListElement": (allTools[cat.slug] ?? []).map((tool: any, i: number) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": tool.name,
    "description": tool.description,
    "url": tool.url ?? tool.github,
  })),
}));
---

<Base>
  {itemLists.map(list => (
    <script type="application/ld+json" set:html={JSON.stringify(list)} />
  ))}

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 pt-16 pb-12 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold text-white tracking-tight mb-4">
      The Solana
      <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #9945FF, #14F195);">
        Toolbox
      </span>
    </h1>
    <p class="text-lg text-gray-400 max-w-2xl mx-auto mb-8">
      A curated directory of {totalTools}+ tools, libraries, and resources for building on and using Solana.
    </p>

    <!-- Category quick-jump links -->
    <div class="flex flex-wrap gap-2 justify-center">
      {categories.map(cat => (
        <a href={`#${cat.slug}`} class="px-4 py-2 rounded-full text-sm font-medium bg-[#1E1E2E] text-gray-300 hover:text-white hover:bg-[#2a2a3e] transition-colors">
          {cat.icon} {cat.name}
        </a>
      ))}
    </div>
  </section>

  <!-- Category sections -->
  <main class="max-w-7xl mx-auto px-4 sm:px-6 pb-16 space-y-16">
    {categories.map(cat => {
      const tools = allTools[cat.slug] ?? [];
      if (tools.length === 0) return null;
      return (
        <section id={cat.slug}>
          <div class="flex items-center gap-3 mb-6 pb-4 border-b border-[#1E1E2E]">
            <span class="text-2xl">{cat.icon}</span>
            <div>
              <h2 class="text-xl font-semibold text-white">{cat.name}</h2>
              <p class="text-sm text-gray-500">{cat.description}</p>
            </div>
            <span class="ml-auto text-xs text-gray-600 font-medium">{tools.length} tools</span>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {tools.map((tool: any) => (
              <ToolCard {...tool} />
            ))}
          </div>
        </section>
      );
    })}
  </main>
</Base>
