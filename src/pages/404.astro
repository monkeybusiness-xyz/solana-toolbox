---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found — Solana Toolbox" description="This page doesn't exist.">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 py-32 text-center">
    <p class="text-xs font-bold uppercase tracking-widest mb-4 text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #9945FF, #14F195);">404</p>
    <h1 class="text-4xl font-bold text-white mb-6">Page not found</h1>
    <p class="text-gray-400 mb-10">That URL doesn't exist.</p>
    <a href="/" class="text-sm font-semibold text-gray-400 hover:text-white transition-colors">
      ← Back to all tools
    </a>
  </main>
</Base>
